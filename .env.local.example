# ---- Airtable ----
# Create a Personal Access Token at https://airtable.com/create/tokens
# Scopes needed: data.records:write, data.records:read
# Scope to the WorkDecoded base only
AIRTABLE_PAT=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---- Google Calendar ----
# 1. Create a service account in Google Cloud Console
# 2. Enable Google Calendar API
# 3. Download the JSON key file
# 4. Share Michelle's calendar with the service account email
# 5. Paste the ENTIRE JSON key file contents here (one line, no line breaks)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com",...}

# The calendar ID to check availability and create events on
# (usually Michelle's email, or a dedicated calendar ID)
GOOGLE_CALENDAR_ID=hello@workdecodedhq.com

# ---- Zapier intake webhook ----
# The public booking form POSTs to /api/book, which forwards the submission to
# this Zapier catch-hook server-side. Keeping it here (server env) instead of in
# public/intake-form.html is the whole point of the intake proxy.
# REQUIRED for bookings to work — set this in Netlify before deploying/merging
# the intake-proxy change, or /api/book returns 503.
ZAPIER_INTAKE_WEBHOOK=https://hooks.zapier.com/hooks/catch/XXXXXXXX/xxxxxxx/

# ---- URL shortener ----
# Bearer token guarding the /api/shorten endpoint (used to shorten Google Meet
# links for SMS).
SHORTENER_API_KEY=xxxxxxxxxxxxxxxxxxxx
