# Link shortener (l.workdecodedhq.com) — routes the API + slug lookups
# to the Next.js handlers. Same ordering rule as the API and asset blocks
# below — must come BEFORE any catch-all that uses the 200! force flag.
https://l.workdecodedhq.com/api/shorten    /api/shorten    200!
https://l.workdecodedhq.com/*              /r/:splat       200!

# API routes on subdomains pass through to the Next.js functions.
# These must come BEFORE the subdomain catch-alls below, otherwise the
# `200!` force flag on those rules will swallow /api/* requests and
# serve the form HTML instead — which then breaks fetch().json() in
# the form's client code.
https://book.workdecodedhq.com/api/*        /api/:splat       200
https://feedback.workdecodedhq.com/api/*    /api/:splat       200

# Static assets on subdomains pass through to the file in /public.
# NOTE: "/:splat" only captures what the splat matched (the bit BEFORE
# the literal extension), so the destination must restore the extension
# (e.g. /:splat.png) — otherwise Netlify looks for a file with no
# extension, doesn't find it, and falls through to the catch-all.
# Same ordering rule as the API block above — must come BEFORE the
# subdomain catch-alls or the `200!` force flag rewrites image / CSS /
# JS requests to the form HTML and the browser fails to render them
# (broken-image icon, MIME-type errors in console, etc.).
https://book.workdecodedhq.com/*.png        /:splat.png           200!
https://book.workdecodedhq.com/*.jpg        /:splat.jpg           200!
https://book.workdecodedhq.com/*.jpeg       /:splat.jpeg           200!
https://book.workdecodedhq.com/*.svg        /:splat.svg           200!
https://book.workdecodedhq.com/*.ico        /:splat.ico           200!
https://book.workdecodedhq.com/*.css        /:splat.css           200!
https://book.workdecodedhq.com/*.js         /:splat.js           200!
https://feedback.workdecodedhq.com/*.png    /:splat.png           200!
https://feedback.workdecodedhq.com/*.jpg    /:splat.jpg           200!
https://feedback.workdecodedhq.com/*.jpeg   /:splat.jpeg           200!
https://feedback.workdecodedhq.com/*.svg    /:splat.svg           200!
https://feedback.workdecodedhq.com/*.ico    /:splat.ico           200!
https://feedback.workdecodedhq.com/*.css    /:splat.css           200!
https://feedback.workdecodedhq.com/*.js     /:splat.js           200!

# Read-only intake view for consultants (lives on the feedback subdomain).
# Lands on the static intake-view.html which calls /api/intake?t=...
# Force flag (200!) so it wins over the subdomain catch-all below.
https://feedback.workdecodedhq.com/intake    /intake-view.html    200!

# Subdomain routing — entire subdomain serves the matching form
https://book.workdecodedhq.com/*        /intake-form.html       200
https://feedback.workdecodedhq.com/*    /feedback-form.html     200

# Clean URLs on the main host
/book        /intake-form.html       200
/feedback    /feedback-form.html     200
